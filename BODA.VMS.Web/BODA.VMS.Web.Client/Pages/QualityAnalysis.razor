@page "/quality-analysis"
@attribute [Authorize]
@inject ApiClient Api
@inject ISnackbar Snackbar
@inject ILocalizer L

<PageTitle>@L["page.paretoAnalysis"] - BODA VMS</PageTitle>

<MudText Typo="Typo.h4" Class="vms-page-title">@L["page.paretoAnalysis"]</MudText>

<div class="vms-panel pa-3 mb-3">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="3">
            <MudDatePicker @bind-Date="_startDate" Label="@(L["common.startDate"])"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudDatePicker @bind-Date="_endDate" Label="@(L["common.endDate"])"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect T="int?" @bind-Value="_clientId" Label="@(L["common.line"])" Clearable="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Router">
                <MudSelectItem T="int?" Value="@((int?)null)">@L["common.all"]</MudSelectItem>
                @foreach (var c in _clients)
                {
                    <MudSelectItem T="int?" Value="@((int?)c.Id)">
                        #@c.ClientIndex.ToString("D2") — @c.Name
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudNumericField T="int" @bind-Value="_topN" Label="@(L["pareto.topN"])"
                             Variant="Variant.Outlined" Margin="Margin.Dense"
                             Min="5" Max="50" />
        </MudItem>
        <MudItem xs="12" sm="1" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Analytics"
                       OnClick="Analyze" Class="vms-btn">@L["action.run"]</MudButton>
        </MudItem>
    </MudGrid>
</div>

@if (_result is not null)
{
    <div class="summary-grid mb-3" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:12px;">
        <div class="vms-panel pa-3">
            <div style="font-size:11px; color: var(--vms-text-secondary); text-transform: uppercase;">@L["pareto.totalInspections"]</div>
            <div style="font-size:24px; font-weight:700; font-family: 'Roboto Mono', monospace;">@_result.TotalInspections.ToString("N0")</div>
        </div>
        <div class="vms-panel pa-3">
            <div style="font-size:11px; color: var(--vms-text-secondary); text-transform: uppercase;">@L["pareto.totalNg"]</div>
            <div style="font-size:24px; font-weight:700; font-family: 'Roboto Mono', monospace; color: var(--mud-palette-error);">@_result.TotalNgCount.ToString("N0")</div>
        </div>
        <div class="vms-panel pa-3">
            <div style="font-size:11px; color: var(--vms-text-secondary); text-transform: uppercase;">@L["pareto.uniqueCodes"]</div>
            <div style="font-size:24px; font-weight:700; font-family: 'Roboto Mono', monospace;">@_result.Entries.Count</div>
        </div>
        <div class="vms-panel pa-3">
            <div style="font-size:11px; color: var(--vms-text-secondary); text-transform: uppercase;">@L["pareto.topShare"]</div>
            <div style="font-size:24px; font-weight:700; font-family: 'Roboto Mono', monospace;">
                @(_result.Entries.FirstOrDefault()?.Percentage.ToString("F1") ?? "0")%
            </div>
        </div>
    </div>

    @if (_result.Entries.Count > 0)
    {
        <div class="vms-panel pa-3 mb-3">
            <MudText Typo="Typo.subtitle1" Class="mb-2">@L.Format("pareto.frequencyTitleFmt", _result.Entries.Count)</MudText>
            <MudChart ChartType="ChartType.Bar"
                      ChartSeries="@_barSeries"
                      XAxisLabels="@_barLabels"
                      Width="100%" Height="320px" />
        </div>

        <div class="vms-table">
            <MudTable Items="_result.Entries" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh Style="width:60px;">@L["pareto.colRank"]</MudTh>
                    <MudTh>@L["pareto.colNgCode"]</MudTh>
                    <MudTh>@L["pareto.colDescription"]</MudTh>
                    <MudTh>@L["pareto.colCategory"]</MudTh>
                    <MudTh>@L["pareto.colSeverity"]</MudTh>
                    <MudTh Style="text-align:right;">@L["pareto.colCount"]</MudTh>
                    <MudTh Style="text-align:right;">@L["pareto.colShare"]</MudTh>
                    <MudTh Style="text-align:right;">@L["pareto.colCumulative"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        @{ var rank = _result.Entries.IndexOf(context) + 1; }
                        <strong>@rank</strong>
                    </MudTd>
                    <MudTd>
                        <span class="vms-mono" style="font-weight:700;">@context.NgCode</span>
                    </MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.Description))
                        {
                            @context.Description
                        }
                        else
                        {
                            <span style="color: var(--vms-text-secondary); font-style: italic;">@L["pareto.unregisteredCode"]</span>
                        }
                    </MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.Category))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Category</MudChip>
                        }
                        else { <span style="color: var(--vms-text-secondary);">—</span> }
                    </MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.Severity))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                     Color="@GetSeverityColor(context.Severity)">@SevLabel(context.Severity, L)</MudChip>
                        }
                    </MudTd>
                    <MudTd Style="text-align:right;"><strong>@context.Count.ToString("N0")</strong></MudTd>
                    <MudTd Style="text-align:right;">
                        <span class="vms-mono">@context.Percentage.ToString("F2")%</span>
                    </MudTd>
                    <MudTd Style="text-align:right;">
                        <div style="display:inline-block; min-width:120px;">
                            <MudProgressLinear Color="@GetCumulativeColor(context.CumulativePercentage)"
                                               Value="@context.CumulativePercentage"
                                               Size="Size.Small" Class="my-1" />
                            <span class="vms-mono" style="font-size:11px;">
                                @context.CumulativePercentage.ToString("F2")%
                            </span>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    }
    else
    {
        <div class="vms-panel pa-8 d-flex flex-column align-center">
            <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large"
                     Style="color: var(--vms-text-secondary); opacity: 0.3;" Class="mb-2" />
            <MudText Style="color: var(--vms-text-secondary);">@L["pareto.noNgData"]</MudText>
        </div>
    }
}
else
{
    <div class="vms-panel pa-8 d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large"
                 Style="color: var(--vms-text-secondary); opacity: 0.3;" Class="mb-2" />
        <MudText Style="color: var(--vms-text-secondary);">@L["pareto.promptRun"]</MudText>
    </div>
}

@code {
    private DateTime? _startDate = DateTime.Today.AddDays(-7);
    private DateTime? _endDate = DateTime.Today.AddDays(1);
    private int? _clientId;
    private int _topN = 20;

    private List<ClientDto> _clients = new();
    private ParetoResultDto? _result;

    private List<ChartSeries> _barSeries = new();
    private string[] _barLabels = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        _clients = await Api.GetAsync<List<ClientDto>>("/api/clients") ?? new();
        await Analyze();
    }

    private async Task Analyze()
    {
        var q = new List<string>();
        if (_startDate.HasValue) q.Add($"startDate={_startDate.Value:yyyy-MM-ddTHH:mm:ss}");
        if (_endDate.HasValue) q.Add($"endDate={_endDate.Value:yyyy-MM-ddTHH:mm:ss}");
        if (_clientId.HasValue) q.Add($"clientId={_clientId}");
        q.Add($"topN={_topN}");
        var url = "/api/defect-codes/pareto?" + string.Join("&", q);
        try
        {
            _result = await Api.GetAsync<ParetoResultDto>(url);
            BuildChart();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(L.Format("snackbar.failedFmt", ex.Message), Severity.Error);
        }
    }

    private void BuildChart()
    {
        if (_result is null || _result.Entries.Count == 0)
        {
            _barSeries = new(); _barLabels = Array.Empty<string>();
            return;
        }

        var entries = _result.Entries;
        _barLabels = entries.Select(e => e.NgCode).ToArray();
        _barSeries = new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = L["pareto.seriesCount"],
                Data = entries.Select(e => (double)e.Count).ToArray()
            }
        };
    }

    private static string SevLabel(string s, ILocalizer L) => s switch
    {
        "Critical" => L["status.critical"],
        "Major" => L["status.major"],
        "Minor" => L["status.minor"],
        _ => s
    };

    private static Color GetSeverityColor(string sev) => sev switch
    {
        "Critical" => Color.Error,
        "Major" => Color.Warning,
        "Minor" => Color.Info,
        _ => Color.Default
    };

    private static Color GetCumulativeColor(double pct)
    {
        if (pct >= 80) return Color.Error;       // 80%까지가 핵심 — 빨강 강조
        if (pct >= 50) return Color.Warning;
        return Color.Info;
    }
}
