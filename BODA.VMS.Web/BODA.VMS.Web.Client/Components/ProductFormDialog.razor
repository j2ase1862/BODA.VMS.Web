@inject ApiClient Api
@inject ISnackbar Snackbar
@inject ILocalizer L

<MudDialog>
    <DialogContent>
        <EditForm Model="Model" OnValidSubmit="Submit">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="Model.Code" Label="@(L["dialog.productFieldCode"])"
                          Variant="Variant.Outlined" Class="mb-4"
                          Required="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.QrCode2"
                          HelperText="@(L["dialog.productFieldCodeHint"])" />

            <MudTextField @bind-Value="Model.Name" Label="@(L["dialog.productFieldName"])"
                          Variant="Variant.Outlined" Class="mb-4"
                          Required="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Inventory" />

            <MudTextField @bind-Value="Model.Specification" Label="@(L["dialog.productFieldSpec"])"
                          Variant="Variant.Outlined" Class="mb-4"
                          Lines="2"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Description"
                          HelperText="@(L["dialog.productFieldSpecHint"])" />

            <MudSelect T="int?" @bind-Value="Model.DefaultRecipeId" Label="@(L["dialog.productFieldDefaultRecipe"])"
                       Variant="Variant.Outlined" Class="mb-4"
                       Clearable="true"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.MenuBook"
                       HelperText="@(L["dialog.productFieldDefaultRecipeHint"])">
                <MudSelectItem T="int?" Value="@((int?)null)">@L["dialog.selectNone"]</MudSelectItem>
                @foreach (var r in _allRecipes)
                {
                    <MudSelectItem T="int?" Value="@((int?)r.Id)">
                        @r.Name @(string.IsNullOrEmpty(r.Description) ? "" : $"— {r.Description}")
                    </MudSelectItem>
                }
            </MudSelect>

            <MudSwitch @bind-Value="Model.IsActive" Label="@(L["status.active"])" Color="Color.Primary" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@L["action.cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="vms-btn">
            @(IsEdit ? L["action.update"] : L["action.create"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ProductDto Model { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }

    private List<RecipeDto> _allRecipes = new();

    protected override async Task OnInitializedAsync()
    {
        // 모든 클라이언트의 레시피를 합쳐서 보여줌 (제품은 라인 무관)
        var clients = await Api.GetAsync<List<ClientDto>>("/api/clients") ?? new();
        foreach (var c in clients)
        {
            var recipes = await Api.GetAsync<List<RecipeDto>>($"/api/clients/{c.Id}/recipes") ?? new();
            _allRecipes.AddRange(recipes);
        }
        _allRecipes = _allRecipes.DistinctBy(r => r.Id).OrderBy(r => r.Name).ToList();
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(Model));
    private void Cancel() => MudDialog.Cancel();
}
