@inject ISnackbar Snackbar
@inject ILocalizer L

<MudDialog>
    <DialogContent>
        <EditForm Model="Model" OnValidSubmit="Submit">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="Model.EmployeeNumber" Label="@(L["dialog.operatorFieldEmpNo"])"
                          Variant="Variant.Outlined" Class="mb-4" Required="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Badge"
                          HelperText="@(L["dialog.operatorFieldEmpNoHint"])" />

            <MudTextField @bind-Value="Model.Name" Label="@(L["dialog.operatorFieldName"])"
                          Variant="Variant.Outlined" Class="mb-4" Required="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person" />

            <MudTextField @bind-Value="Model.Department" Label="@(L["dialog.operatorFieldDepartment"])"
                          Variant="Variant.Outlined" Class="mb-4"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Business" />

            <MudTextField @bind-Value="Model.Pin" Label="@(IsEdit ? L["dialog.operatorFieldPinEdit"] : L["dialog.operatorFieldPin"])"
                          Variant="Variant.Outlined" Class="mb-4"
                          InputType="InputType.Password"
                          Required="@(!IsEdit)"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Pin"
                          HelperText="@(L["dialog.operatorFieldPinHint"])" />

            <MudSelect T="string" @bind-Value="Model.Role" Label="Role / 등급"
                       Variant="Variant.Outlined" Class="mb-4"
                       AdornmentIcon="@Icons.Material.Filled.Shield"
                       Adornment="Adornment.Start"
                       HelperText="VMS 메뉴 가시성 제어 — Operator (일반) / Lead (반장) / Supervisor (관리자)">
                <MudSelectItem Value="@("Operator")">Operator (일반 작업자)</MudSelectItem>
                <MudSelectItem Value="@("Lead")">Lead (반장)</MudSelectItem>
                <MudSelectItem Value="@("Supervisor")">Supervisor (관리자)</MudSelectItem>
            </MudSelect>

            <MudSwitch @bind-Value="Model.IsActive" Label="@(L["status.active"])" Color="Color.Primary" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@L["action.cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="vms-btn">
            @(IsEdit ? L["action.update"] : L["action.create"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public OperatorUpsertDto Model { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }

    private void Submit() => MudDialog.Close(DialogResult.Ok(Model));
    private void Cancel() => MudDialog.Cancel();
}
