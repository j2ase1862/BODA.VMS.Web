@inject ApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject ILocalizer L

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="mr-2" />
            @L.Format("dialog.lotListTitleFmt", WorkOrderNo)
        </MudText>
    </TitleContent>
    <DialogContent>
        <div style="min-width: 600px;">
            <div class="d-flex align-center mb-3">
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                    @L["dialog.lotListHint"]
                </MudText>
                <MudSpacer />
                <AuthorizeView Roles="Admin,User" Context="authHeader">
                    <Authorized>
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                   Variant="Variant.Filled" Size="Size.Small"
                                   OnClick="CreateLot" Class="vms-btn">
                            @L["dialog.lotListBtnCreate"]
                        </MudButton>
                    </Authorized>
                </AuthorizeView>
            </div>

            <MudTable Items="_lots" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>@L["dialog.lotListColNumber"]</MudTh>
                    <MudTh Style="text-align: right;">@L["dialog.lotListColQty"]</MudTh>
                    <MudTh Style="text-align: right;">@L["dialog.lotListColPass"]</MudTh>
                    <MudTh Style="text-align: right;">@L["dialog.lotListColNg"]</MudTh>
                    <MudTh Style="text-align: right;">@L["dialog.lotListColNgRate"]</MudTh>
                    <MudTh>@L["common.status"]</MudTh>
                    <MudTh>@L["dialog.lotListColCreatedAt"]</MudTh>
                    <MudTh Style="text-align: right;">@L["common.actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <span class="vms-mono" style="font-weight: 600;">@context.LotNumber</span>
                    </MudTd>
                    <MudTd Style="text-align: right;">@context.Quantity</MudTd>
                    <MudTd Style="text-align: right; color: var(--mud-palette-success);">@context.PassCount</MudTd>
                    <MudTd Style="text-align: right; color: var(--mud-palette-error);">@context.NgCount</MudTd>
                    <MudTd Style="text-align: right;">@context.NgRate.ToString("F2")%</MudTd>
                    <MudTd>
                        @if (context.Status == "Open")
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@L["dialog.lotListStatusOpen"]</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@L["dialog.lotListStatusClosed"]</MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption">@context.CreatedAt.ToLocalTime().ToString("MM-dd HH:mm")</MudText>
                    </MudTd>
                    <MudTd Style="text-align: right;">
                        @{
                            var lot = context;
                        }
                        @if (lot.Status == "Open")
                        {
                            <AuthorizeView Roles="Admin,User" Context="authRow">
                                <Authorized>
                                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small"
                                                   Color="Color.Warning"
                                                   OnClick="@(() => CloseLot(lot))" />
                                </Authorized>
                            </AuthorizeView>
                        }
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-6 text-center" style="color: var(--vms-text-secondary);">
                        @L["dialog.lotListNoData"]
                    </div>
                </NoRecordsContent>
            </MudTable>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">@L["action.close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int WorkOrderId { get; set; }
    [Parameter] public string WorkOrderNo { get; set; } = "";

    private List<LotDto> _lots = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _lots = await Api.GetAsync<List<LotDto>>(
            $"/api/workorders/{WorkOrderId}/lots") ?? new();
    }

    private async Task CreateLot()
    {
        try
        {
            var lot = await Api.PostAsync<CreateLotRequest, LotDto>(
                $"/api/workorders/{WorkOrderId}/lots",
                new CreateLotRequest { Note = null });
            Snackbar.Add(L.Format("dialog.lotListCreatedFmt", lot?.LotNumber ?? ""), Severity.Success);
            await Load();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(L.Format("snackbar.failedFmt", ex.Message), Severity.Error);
        }
    }

    private async Task CloseLot(LotDto lot)
    {
        var confirmed = await Dialog.ShowMessageBox(L["dialog.lotListConfirmCloseTitle"],
            L.Format("dialog.lotListConfirmCloseFmt", lot.LotNumber),
            L["dialog.lotListBtnClose"], L["action.cancel"]);
        if (confirmed != true) return;

        try
        {
            await Api.PostAsync<object, LotDto>($"/api/lots/{lot.Id}/close", new { });
            Snackbar.Add(L.Format("dialog.lotListClosedFmt", lot.LotNumber), Severity.Warning);
            await Load();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(L.Format("snackbar.failedFmt", ex.Message), Severity.Error);
        }
    }

    private void Close() => MudDialog.Close();
}
