@inject ApiClient Api
@inject ISnackbar Snackbar
@inject ILocalizer L

<MudDialog>
    <DialogContent>
        <EditForm Model="Model" OnValidSubmit="Submit">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="Model.Name" Label="@(L["dialog.maintFieldName"])"
                          Variant="Variant.Outlined" Class="mb-4" Required="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Build" />

            <MudTextField @bind-Value="Model.Description" Label="@(L["dialog.maintFieldDescription"])"
                          Variant="Variant.Outlined" Class="mb-4" Lines="2"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Description" />

            <MudSelect T="int?" @bind-Value="Model.ClientId" Label="@(L["dialog.maintFieldClient"])" Clearable="true"
                       Variant="Variant.Outlined" Class="mb-4"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Router"
                       HelperText="@(L["dialog.maintFieldClientHint"])">
                <MudSelectItem T="int?" Value="@((int?)null)">@L["dialog.maintFieldClientAll"]</MudSelectItem>
                @foreach (var c in _clients)
                {
                    <MudSelectItem T="int?" Value="@((int?)c.Id)">
                        #@c.ClientIndex.ToString("D2") @c.Name
                    </MudSelectItem>
                }
            </MudSelect>

            <MudGrid Spacing="2" Class="mb-4">
                <MudItem xs="6">
                    <MudNumericField T="int" @bind-Value="Model.IntervalDays" Label="@(L["dialog.maintFieldInterval"])"
                                     Variant="Variant.Outlined" Min="1"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Repeat"
                                     HelperText="@(L["dialog.maintFieldIntervalHint"])" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField T="int" @bind-Value="Model.EstimatedDurationMinutes" Label="@(L["dialog.maintFieldDuration"])"
                                     Variant="Variant.Outlined" Min="1"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Timer" />
                </MudItem>
            </MudGrid>

            <MudDatePicker @bind-Date="Model.NextDueAt" Label="@(L["dialog.maintFieldNextDue"])"
                           Variant="Variant.Outlined" Class="mb-4"
                           Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                           HelperText="@(L["dialog.maintFieldNextDueHint"])" />

            <MudSwitch @bind-Value="Model.IsActive" Label="@(L["status.active"])" Color="Color.Primary" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@L["action.cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="vms-btn">
            @(IsEdit ? L["action.update"] : L["action.create"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public MaintenanceScheduleUpsertDto Model { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }

    private List<ClientDto> _clients = new();

    protected override async Task OnInitializedAsync()
    {
        _clients = await Api.GetAsync<List<ClientDto>>("/api/clients") ?? new();
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(Model));
    private void Cancel() => MudDialog.Cancel();
}
