@inject ISnackbar Snackbar
@inject ILocalizer L

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Name" Label="@(L["dialog.recipeFieldName"])"
                      Variant="Variant.Outlined" Class="mb-4"
                      Placeholder="S25_BackGlass, APPLE_I15_CASE"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.MenuBook" />

        <MudTextField @bind-Value="Description" Label="@(L["dialog.recipeFieldDescription"])"
                      Variant="Variant.Outlined" Class="mb-4"
                      Placeholder="@(L["dialog.recipeFieldDescriptionPlaceholder"])"
                      Lines="2" />

        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mt-2">
            @L["dialog.recipeAlertInfo"]
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@L["action.cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@string.IsNullOrWhiteSpace(Name)"
                   Class="vms-btn">
            @L["action.create"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private MudDialogInstance MudDialog { get; set; } = null!;

    public string Name { get; set; } = string.Empty;
    public string Description { get; set; } = string.Empty;

    private void Submit() => MudDialog.Close(DialogResult.Ok(new RecipeDto
    {
        Name = Name,
        Description = Description
    }));

    private void Cancel() => MudDialog.Cancel();
}
