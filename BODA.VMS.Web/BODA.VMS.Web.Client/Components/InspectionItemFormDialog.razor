@inject ISnackbar Snackbar
@inject ILocalizer L

<MudDialog>
    <DialogContent>
        <EditForm Model="Model" OnValidSubmit="Submit">
            <DataAnnotationsValidator />

            <MudSelect T="string" Value="Model.Category" ValueChanged="OnCategoryChanged"
                       Label="@(L["dialog.inspParamCategory"])"
                       Variant="Variant.Outlined" Class="mb-4"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Category">
                <MudSelectItem T="string" Value="@("Pattern")">@L["dialog.inspCategoryPattern"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("Blob")">@L["dialog.inspCategoryBlob"]</MudSelectItem>
                <MudSelectItem T="string" Value="@("Dimension")">@L["dialog.inspCategoryDimension"]</MudSelectItem>
            </MudSelect>

            @if (!string.IsNullOrEmpty(Model.Category))
            {
                <MudAlert Severity="@GetCategorySeverity(Model.Category)" Variant="Variant.Text"
                          Dense="true" Class="mb-4" NoIcon="false">
                    @(ParameterPresetGroup.GetCategoryDescription(Model.Category))
                </MudAlert>
            }

            <MudNumericField T="int" Value="Model.ParamCode" ValueChanged="OnParamCodeChanged"
                             Label="@(L["dialog.inspFieldParamCode"])"
                             Variant="Variant.Outlined" Class="mb-4"
                             Min="1"
                             Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.Tag"
                             Style="font-family: 'Roboto Mono', monospace;"
                             Error="@_isDuplicate"
                             ErrorText="@_duplicateMessage"
                             HelperText="@(_isDuplicate ? "" : L["dialog.inspFieldParamCodeHint"])" />

            <MudNumericField @bind-Value="Model.ParamValue" Label="@(L["dialog.inspFieldValue"])"
                             Variant="Variant.Outlined" Class="mb-4"
                             Format="F4"
                             Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.Numbers" />

            <MudTextField @bind-Value="Model.Description" Label="@(L["dialog.inspFieldDescription"])"
                          Variant="Variant.Outlined" Class="mb-4"
                          Placeholder="@GetDescPlaceholder(Model.Category, L)"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Description" />

            <MudTextField @bind-Value="Model.Unit" Label="@(L["dialog.inspFieldUnit"])"
                          Variant="Variant.Outlined" Class="mb-4"
                          Placeholder="@GetUnitPlaceholder(Model.Category)"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Straighten" />

            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="6">
                    <MudNumericField T="double?" @bind-Value="Model.LowerLimit" Label="@(L["dialog.inspFieldLowerLimit"])"
                                     Variant="Variant.Outlined" Format="F4" Clearable="true"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.VerticalAlignBottom"
                                     HelperText="@(L["dialog.inspFieldLowerLimitHint"])" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField T="double?" @bind-Value="Model.UpperLimit" Label="@(L["dialog.inspFieldUpperLimit"])"
                                     Variant="Variant.Outlined" Format="F4" Clearable="true"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.VerticalAlignTop"
                                     HelperText="@(L["dialog.inspFieldUpperLimitHint"])" />
                </MudItem>
            </MudGrid>

            <MudSwitch @bind-Value="Model.IsActive" Label="@(L["status.active"])" Color="Color.Primary" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@L["action.cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(_isDuplicate && !IsEdit)"
                   Class="vms-btn">
            @(IsEdit ? L["action.update"] : L["action.create"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public RecipeParameterDto Model { get; set; } = new();

    [Parameter]
    public bool IsEdit { get; set; }

    /// <summary>
    /// 현재 레시피에 이미 존재하는 ParamCode 목록 (중복 체크용)
    /// </summary>
    [Parameter]
    public HashSet<int> ExistingCodes { get; set; } = new();

    private bool _isDuplicate;
    private string _duplicateMessage = "";

    private void OnParamCodeChanged(int newCode)
    {
        Model.ParamCode = newCode;
        CheckDuplicate(newCode);
    }

    private void CheckDuplicate(int code)
    {
        // 편집 모드에서 자기 자신의 코드는 중복이 아님
        if (IsEdit && code == Model.ParamCode)
        {
            _isDuplicate = false;
            _duplicateMessage = "";
            return;
        }

        if (ExistingCodes.Contains(code))
        {
            _isDuplicate = true;
            _duplicateMessage = L.Format("dialog.inspDuplicateCodeFmt", code);
        }
        else
        {
            _isDuplicate = false;
            _duplicateMessage = "";
        }
    }

    private void OnCategoryChanged(string newCategory)
    {
        Model.Category = newCategory;
    }

    private static Severity GetCategorySeverity(string category) => category switch
    {
        "Pattern" => Severity.Info,
        "Blob" => Severity.Warning,
        "Dimension" => Severity.Success,
        _ => Severity.Normal
    };

    private static string GetDescPlaceholder(string category, ILocalizer L) => category switch
    {
        "Pattern" => L["dialog.inspDescPlaceholderPattern"],
        "Blob" => L["dialog.inspDescPlaceholderBlob"],
        "Dimension" => L["dialog.inspDescPlaceholderDimension"],
        _ => L["dialog.inspDescPlaceholderDefault"]
    };

    private static string GetUnitPlaceholder(string category) => category switch
    {
        "Pattern" => "score, deg, ratio, mm, px",
        "Blob" => "ea, px, level",
        "Dimension" => "mm",
        _ => "mm, px, score"
    };

    private void Submit()
    {
        if (_isDuplicate && !IsEdit)
        {
            Snackbar.Add(L.Format("dialog.inspDuplicateSnackFmt", Model.ParamCode), Severity.Error);
            return;
        }
        MudDialog.Close(DialogResult.Ok(Model));
    }

    private void Cancel() => MudDialog.Cancel();
}
