@inject ApiClient Api
@inject ILocalizer L

<MudDialog>
    <DialogContent>
        <div style="min-width: 420px;">
            <MudText Typo="Typo.subtitle1" Class="mb-1">@Schedule.Name</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--vms-text-secondary);" Class="mb-3">
                @L.Format("dialog.performInfoFmt", Schedule.IntervalDays, Schedule.EstimatedDurationMinutes)
            </MudText>

            @if (!Schedule.ClientId.HasValue)
            {
                <MudSelect T="int?" @bind-Value="_clientId" Label="@(L["dialog.performFieldClient"])"
                           Variant="Variant.Outlined" Class="mb-3" Required="true"
                           HelperText="@(L["dialog.performFieldClientHint"])">
                    <MudSelectItem T="int?" Value="@((int?)null)">@L["dialog.selectPlaceholder"]</MudSelectItem>
                    @foreach (var c in _clients)
                    {
                        <MudSelectItem T="int?" Value="@((int?)c.Id)">
                            #@c.ClientIndex.ToString("D2") @c.Name
                        </MudSelectItem>
                    }
                </MudSelect>
            }

            <MudNumericField T="int?" @bind-Value="_duration" Label="@(L["dialog.performFieldDuration"])"
                             Variant="Variant.Outlined" Class="mb-3"
                             Min="1" Clearable="true"
                             HelperText="@(L["dialog.performFieldDurationHint"])" />

            <MudTextField @bind-Value="_notes" Label="@(L["dialog.performFieldNotes"])"
                          Variant="Variant.Outlined" Lines="3"
                          HelperText="@(L["dialog.performFieldNotesHint"])" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@L["action.cancel"]</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!Schedule.ClientId.HasValue && !_clientId.HasValue)"
                   Class="vms-btn">
            @L["dialog.performBtnRecord"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public MaintenanceScheduleDto Schedule { get; set; } = new();

    private List<ClientDto> _clients = new();
    private int? _clientId;
    private int? _duration;
    private string _notes = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Schedule.ClientId.HasValue)
            _clients = await Api.GetAsync<List<ClientDto>>("/api/clients") ?? new();
    }

    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(new PerformMaintenanceRequest
        {
            ClientId = _clientId ?? Schedule.ClientId,
            ActualDurationMinutes = _duration,
            Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes
        }));
    }

    private void Cancel() => MudDialog.Cancel();
}
